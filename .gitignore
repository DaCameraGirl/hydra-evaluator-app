# Dependencies (none yet, but guard against future tooling)
node_modules/

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/

# Local secrets — the app stores the API key in browser localStorage,
# never on disk, but guard against accidental commits of any env files.
.env
.env.*

# Image assets live outside the repo (the 285 MB Project Hydra dump).
# Don't pull them in if someone drops samples into the app folder.
*.png
*.jpg
*.jpeg
*.webp
